# ══════════════════════════════════════════════════════════
# Variables de entorno para producción – PinataPoster
# Copia este archivo y renómbralo a .env.local (desarrollo)
# o configúralas en el dashboard de Railway (producción).
# ══════════════════════════════════════════════════════════

# ── NextAuth ─────────────────────────────────────────────
# URL base de tu app (ej: https://tudominio.com)
NEXTAUTH_URL=
# Secreto para firmar tokens (genera uno con: openssl rand -base64 32)
NEXTAUTH_SECRET=

# ── Google OAuth ─────────────────────────────────────────
# Credenciales de Google Cloud Console
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Stripe ───────────────────────────────────────────────
# Clave secreta de Stripe (sk_live_... o sk_test_...)
STRIPE_SECRET_KEY=
# Secreto del webhook de Stripe (whsec_...)
STRIPE_WEBHOOK_SECRET=
# IDs de precios de los packs de diseños en Stripe
STRIPE_PRICE_PACK_5=
STRIPE_PRICE_PACK_15=
STRIPE_PRICE_PACK_50=

# ── Replicate (AI Upscale) ──────────────────────────────
# Token de API de Replicate para upscale de imágenes
REPLICATE_API_TOKEN=
