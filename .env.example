# ══════════════════════════════════════════════════════════
# Variables de entorno – PinataPoster
# Copia este archivo y renómbralo a .env.local (desarrollo)
# o configúralas en Cloud Run (producción).
# ══════════════════════════════════════════════════════════

# ── Admin ────────────────────────────────────────────────
# Contraseña para acceder al panel de administración (/admin)
ADMIN_PASSWORD=

# ── Feature flags ─────────────────────────────────────────
# Deshabilitar /chat en producción (true = bloqueado, false/ausente = disponible)
DISABLE_CHAT=false

# ── Google AI Studio (MoldeIA + Upscale) ─────────────────
# Obtén tu API Key en: https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=

# ── Firebase Auth (Catálogo Digital) ─────────────────────
# Configuración del SDK cliente de Firebase
# Obtener en: Firebase Console → Project Settings → Web App
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=rutas-488705
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Firebase Admin (Server-side) ─────────────────────────
# JSON del service account key (solo para desarrollo local)
# En Cloud Run usa ADC (Application Default Credentials) automáticamente
FIREBASE_SERVICE_ACCOUNT_KEY=

# ── Google Cloud Storage ─────────────────────────────────
# Bucket para imágenes de catálogo (logos, fotos de productos)
GCS_BUCKET_NAME=pinataposter-media

# ── Stripe (Acceso Preferencial) ─────────────────────────
# Obtener en: Stripe Dashboard → Developers → API Keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
# Obtener en: Stripe Dashboard → Developers → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET=
